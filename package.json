{
  "name": "fintech-fraud-sim",
  "version": "0.1.1",
  "description": "Synthetic fintech user and transaction fraud simulation CLI for testing fraud systems.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "fintech-fraud-sim": "./dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "pretest": "tsc",
    "test": "node --test tests/*.test.mjs",
    "dev": "tsc && node dist/cli.js",
    "prepublishOnly": "tsc && node --test tests/*.test.mjs"
  },
  "keywords": [
    "fraud",
    "fintech",
    "synthetic-data",
    "risk",
    "cli",
    "csv",
    "json"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@faker-js/faker": "^9.9.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.17.2",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18.18"
  }
}
