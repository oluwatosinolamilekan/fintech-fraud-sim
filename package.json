{
  "name": "fintech-fraud-sim",
  "version": "0.2.0",
  "description": "Synthetic fintech user and transaction fraud simulation CLI for testing fraud systems.",
  "type": "module",
  "author": "Lamidi Olamilekan",
  "packageManager": "npm@11.3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oluwatosinolamilekan/fintech-fraud-sim.git"
  },
  "bugs": {
    "url": "https://github.com/oluwatosinolamilekan/fintech-fraud-sim/issues"
  },
  "homepage": "https://github.com/oluwatosinolamilekan/fintech-fraud-sim#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "fintech-fraud-sim": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "pretest": "tsc",
    "test": "node --test tests/*.test.mjs",
    "dev": "tsc && node dist/cli.js",
    "publish:ci": "npm publish --provenance --access public",
    "publish:local": "npm publish --access public",
    "prepublishOnly": "tsc && node --test tests/*.test.mjs"
  },
  "keywords": [
    "fraud",
    "fintech",
    "synthetic-data",
    "risk",
    "cli",
    "csv",
    "json"
  ],
  "license": "MIT",
  "dependencies": {
    "@faker-js/faker": "9.9.0",
    "commander": "12.1.0"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18.18"
  }
}
