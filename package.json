{
  "name": "fintech-fraud-sim",
  "version": "0.4.2",
  "description": "Synthetic fintech user and transaction fraud simulation CLI for testing fraud systems.",
  "type": "module",
  "author": "Lamidi Olamilekan",
  "packageManager": "npm@11.3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oluwatosinolamilekan/fintech-fraud-sim.git"
  },
  "bugs": {
    "url": "https://github.com/oluwatosinolamilekan/fintech-fraud-sim/issues"
  },
  "homepage": "https://github.com/oluwatosinolamilekan/fintech-fraud-sim#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "fintech-fraud-sim": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "demo",
    "examples",
    "schemas",
    "README.md",
    "SECURITY.md",
    "socket.yml",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "pretest": "tsc",
    "test": "node --test tests/*.test.mjs",
    "dev": "tsc && node dist/cli.js",
    "publish:ci": "npm run build && node --test tests/*.test.mjs && npm publish --ignore-scripts --provenance --access public",
    "publish:local": "npm run build && node --test tests/*.test.mjs && npm publish --ignore-scripts --access public --provenance=false",
    "prepublishOnly": "tsc && node --test tests/*.test.mjs"
  },
  "keywords": [
    "fraud",
    "fintech",
    "synthetic-data",
    "risk",
    "cli",
    "csv",
    "json"
  ],
  "license": "MIT",
  "dependencies": {
    "@faker-js/faker": "10.5.0",
    "commander": "15.0.0"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
